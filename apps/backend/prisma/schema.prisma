generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String?
  name        String
  slug        String   @unique
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  endpoints        Endpoint[]
  globalConfig     GlobalConfig?
  logs             ApiLog[]
  auditEvents      AuditEvent[]
  rateLimitBuckets RuntimeRateLimitBucket[]

  @@index([workspaceId])
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  externalIdentities ExternalIdentity[]
  memberships        WorkspaceMembership[]
  personalWorkspace  Workspace?             @relation("PersonalWorkspaceOwner")
}

model Workspace {
  id                String   @id @default(cuid())
  name              String
  slug              String?  @unique
  kind              String   @default("team")
  personalForUserId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  personalForUser User?                  @relation("PersonalWorkspaceOwner", fields: [personalForUserId], references: [id], onDelete: SetNull)
  memberships     WorkspaceMembership[]
  projects        Project[]
}

model WorkspaceMembership {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("owner")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model ExternalIdentity {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  subject       String
  email         String?
  emailVerified Boolean  @default(false)
  displayName   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([userId])
}

model Endpoint {
  id           String   @id @default(cuid())
  projectId    String
  method       String
  path         String
  description  String   @default("")
  statusCode   Int      @default(200)
  responseBody Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenarios      Scenario[]
  endpointConfig EndpointConfig?

  @@unique([projectId, method, path])
}

model Scenario {
  id         String   @id @default(cuid())
  endpointId String
  name       String
  type       String
  statusCode Int
  body       Json
  delayMs    Int      @default(0)
  weight     Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  endpoint Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model EndpointConfig {
  id                 String   @id @default(cuid())
  endpointId         String   @unique
  latencyMode        String   @default("fixed")
  fixedDelayMs       Int      @default(0)
  minDelayMs         Int      @default(0)
  maxDelayMs         Int      @default(500)
  errorRate          Float    @default(0)
  useScenarioWeights Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  endpoint Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

model GlobalConfig {
  id                     String   @id @default(cuid())
  projectId              String   @unique
  latencyEnabled         Boolean  @default(false)
  latencyMinMs           Int      @default(0)
  latencyMaxMs           Int      @default(1000)
  latencyMode            String   @default("fixed")
  errorSimulationEnabled Boolean  @default(false)
  errorSimulationRate    Float    @default(0)
  errorSimulationCodes   Json     @default("[500]")
  rateLimitingEnabled    Boolean  @default(false)
  rateLimitingRpm        Int      @default(60)
  loggingLevel           String   @default("basic")
  scope                  String   @default("all")
  updatedAt              DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ApiLog {
  id                      String   @id @default(cuid())
  projectId               String
  method                  String
  path                    String
  fullUrl                 String
  origin                  String
  statusCode              Int
  latencyMs               Int
  scenarioType            String
  scenarioSelectionSource String
  scenarioName            String?
  requestHeaders          Json
  requestBody             Json?
  responseHeaders         Json
  responseBody            Json
  createdAt               DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc), id(sort: Desc)])
}

model AuditEvent {
  id               String   @id @default(cuid())
  actorUserId      String
  actorEmail       String?
  actorDisplayName String?
  workspaceId      String
  projectId        String
  resourceType     String
  resourceId       String
  action           String
  summary          String
  metadata         Json?
  createdAt        DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([projectId, resourceType, createdAt(sort: Desc), id(sort: Desc)])
  @@index([projectId, action, createdAt(sort: Desc), id(sort: Desc)])
}

model RuntimeRateLimitBucket {
  projectId    String
  windowStart  DateTime
  requestCount Int      @default(0)
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([projectId, windowStart])
  @@index([windowStart])
}
